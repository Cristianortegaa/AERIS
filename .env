PORT=3000

# VAPID keys para notificaciones push.
# Genera las tuyas con: node -e "const wp=require('web-push'); const keys=wp.generateVAPIDKeys(); console.log(keys);"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Secret para proteger el endpoint del cron job /api/cron/check-rain
# Ponlo también en tu servicio de cron (cabecera x-cron-secret: ESTE_VALOR)
CRON_SECRET=cambia-esto-por-un-secreto-seguro

# Orígenes permitidos para CORS (separados por coma).
# Si no se define, se permite cualquier origen (comportamiento anterior).
# Ejemplo: ALLOWED_ORIGIN=https://aeris-ghg8.onrender.com
ALLOWED_ORIGIN=
